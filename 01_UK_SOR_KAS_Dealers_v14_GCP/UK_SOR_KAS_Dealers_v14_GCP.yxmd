<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2024.2">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="162" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Passwords />
          <CachedCosmeticName />
          <File RecordLimit="" FileFormat="23">aka:GCP_BQ|||SELECT
  DISTINCT INV.EDWAZ28_SEL_DLR_MKT_I2_CNTRY_C AS MARKET,
  INV.EDWAZ28_MAPPED_SELL_DLR_C AS DEALER,
  --RD.EDWA006_MAPPED_DEPT_TYPE_F,
  --INV.EDWAO26_INVOICE_TYPE_C,
  CASE
    WHEN RD.EDWA006_MAPPED_DEPT_TYPE_F IS NULL THEN INV.EDWAO26_INVOICE_TYPE_C
    WHEN INV.EDWAO26_INVOICE_TYPE_C IS NULL THEN RD.EDWA006_MAPPED_DEPT_TYPE_F
    ELSE RD.EDWA006_MAPPED_DEPT_TYPE_F
  END
    AS DEPARTMENT,
  INV.EDWAZ12_MAPPED_PMT_TYPE_C AS PAYMENT_TYPE,
  INV.EDWAO26_INVOICE_Y AS INV_DATE,
  INV.EDWAO26_INVOICE_INDICATOR_C AS INVOICE_TYPE,
  INV.EDWAO26_NET_TOTAL_INV_VALUE_A AS INV_TOTAL_LOCAL,
  VEH.EDWAO28_VIN_C AS VIN,
  VEH.EDWAO28_REGISTRATION_PLATE_C AS REG_PLATE,
  CASE
    WHEN RD.EDWA006_VEH_TYPE_C IS NULL THEN '#'
    ELSE RD.EDWA006_VEH_TYPE_C
  END
    AS VEH_TYPE,
  CASE
    WHEN RD.EDWA006_VEH_ENG_FUEL_TYPE_C IS NULL THEN CASE
    WHEN VEH.EDWAO28_FUEL_INDICATOR_C = 'P' THEN 'G'
    ELSE VEH.EDWAO28_FUEL_INDICATOR_C
  END
      ELSE RD.EDWA006_VEH_ENG_FUEL_TYPE_C
  END
    AS FUEL_TYPE,
  TR.SSAVA02_VEH_DESCRIPTION_N AS VEH_DESCRIPTION,
  CUST.EDWAO30_ACCOUNT_C AS ACCOUNT_CODE,
  CUST.EDWAO30_CUST_DISPLAY_N AS CUSTOMER_NAME_AGREGATED,
  CUST.EDWAO30_CUST_DISPLAY_ADDR_X AS CUSTOMER_ADD_AGREGATED,
  CUST.EDWAO30_ORIG_LST_N AS LAST_NAME,
  CUST.EDWAO30_ORIG_1ST_N AS FIRST_NAME,
  CUST.EDWAO30_ORIG_TITLE_N AS TITLE_,
  CUST.EDWAO30_ORIG_COMP_1ST_N AS COMPANY_NAME_1,
  CUST.EDWAO30_ORIG_COMP_2ND_N AS COMPANY_NAME_2,
  CUST.EDWAO30_ORIG_STREET_N AS STREET,
  CUST.EDWAO30_ORIG_CITY_RGN_N AS REGION,
  CUST.EDWAO30_ORIG_CITY_N AS CITY,
  CUST.EDWAO30_ORIG_CNTY_N AS COUNTY,
  CUST.EDWAO30_ORIG_POSTCODE_C AS POSTCODE,
  CUST.EDWAO30_ORIG_ADDR_L_1_X AS ADDR_1,
  CUST.EDWAO30_ORIG_ADDR_L_2_X AS ADDR_2,
  CUST.EDWAO30_ORIG_ADDR_L_3_X AS ADDR_3,
  CUST.EDWAO30_ORIG_ADDR_L_4_X AS ADDR_4,
  CUST.EDWAO30_ORIG_ADDR_L_5_X AS ADDR_5,
  CUST.EDWAO30_ORIG_ADDR_L_6_X AS ADDR_6,
  CUST.EDWAO30_HOME_TEL_R AS HOME_TEL,
  CUST.EDWAO30_WORK_TEL_R AS WORK_TEL,
  CUST.EDWAO30_PRO_TITLE_N AS PRO_TITLE,
  CUST.EDWAO30_FIRST_MOBILE_TEL_R AS MOBILE_1,
  CUST.EDWAO30_SECOND_MOBILE_TEL_R AS MOBILE_2,
  CUST.EDWAO30_FIRST_EMAIL_ADDRESS_X AS EMAIL_1,
  CUST.EDWAO30_SECOND_EMAIL_ADDRESS_X AS EMAIL_2,
  CUST.EDWAO30_LETTER_SALUTATION_X AS SALUTATION,
  TR.EDWA007_VEHICLE_CATEGORY AS PV_CV,
  CASE
    WHEN CUST.EDWAO30_ORIG_COMP_1ST_N IN ('#') OR CUST.EDWAO30_ORIG_COMP_2ND_N IN ('#') THEN 'I'
    WHEN LENGTH(CUST.EDWAO30_ORIG_COMP_1ST_N) &gt; 1
  OR LENGTH(CUST.EDWAO30_ORIG_COMP_2ND_N) &gt; 1 THEN 'O'
    ELSE CUST.EDWAO30_CUSTOMER_TYPE_C
  END
    AS CUSTOMER_TYPE

FROM
  prj-dfad-1242-uapd-p-1242.bq_594_sor_bq_lc_vw.edwao28_veh_acpt_inv_vw AS VEH
INNER JOIN
  prj-dfad-1242-uapd-p-1242.bq_594_sor_bq_lc_vw.edwao26_acpt_inv_vw AS INV
ON
  VEH.EDWA006_INV_KEY_K = INV.EDWA006_INV_KEY_K
INNER JOIN
  prj-dfad-1242-uapd-p-1242.bq_594_sor_bq_lc_vw.edwao30_cust_catalogue_vw AS CUST
ON
  INV.EDWAO30_REVENUE_ASN_CUST_KEY_K = CUST.EDWAO30_CUST_KEY_K
LEFT JOIN
  prj-dfad-1242-uapd-p-1242.bq_594_sor_bq_lc_vw.edwa006_report_data_vw AS RD
ON
  RD.EDWA006_INV_KEY_K = VEH.EDWA006_INV_KEY_K
INNER JOIN
  prj-dfad-1242-uapd-p-1242.bq_594_sor_bq_lc_vw.edwa007_traffic_report_data_vw AS TR
ON
  VEH.EDWAO28_VIN_C = TR.EDWAO28_VIN_C
WHERE
  INV.EDWAZ28_MAPPED_SELL_DLR_C IN ('47114DA','84465AA','47114AA','47114CA','81594AA','83556AA',
    '75259DA','85795AA','50669AA','46192AA','51171','51130','51172','51041','44695BA','61567AA','61567AA','61502AA','64509AA','83556EA',
    '44695LA','43301BA','83883DA','83883AA','72707BA','72707CA','67671CA')

  AND INV.EDWAZ28_SEL_DLR_MKT_I2_CNTRY_C IN ('GB','IE')
  AND INV.EDWAO26_NET_TOTAL_INV_VALUE_A &gt;= 43
  AND INV.EDWAO26_INVOICE_INDICATOR_C IN ('380')
  AND INV.EDWAO26_INVOICE_Y BETWEEN (CURRENT_DATE - INTERVAL '10' DAY)
  AND current_date
  AND TR.SSAVA02_VEH_DESCRIPTION_N NOT IN ('#')
  AND (RD.EDWA006_MAPPED_DEPT_TYPE_F IN ('S') OR INV.EDWAO26_INVOICE_TYPE_C IN ('S'))
  AND(
    INV.EDWAZ12_MAPPED_PMT_TYPE_C IN ('R','W')
    OR
    INV.EDWAZ12_MAPPED_PMT_TYPE_C IN ('F')
    AND (CUST.EDWAO30_ORIG_COMP_1ST_N IN ('#') AND CUST.EDWAO30_ORIG_COMP_2ND_N IN ('#')) -- this means that the CUSTOMER_TYPE is 'I' above*/ )
  )</File>
          <FormatSpecificOptions>
            <PreSQL />
            <PreSQLOnConfig>True</PreSQLOnConfig>
            <NoProgress>True</NoProgress>
            <SessionReadOnly>True</SessionReadOnly>
            <CacheData>False</CacheData>
            <TableStyle>Quoted</TableStyle>
            <ReadUncommitted>False</ReadUncommitted>
            <PostSQL />
          </FormatSpecificOptions>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>aka:GCP_BQ
Query=SELECT
  DISTINCT INV.EDWAZ...</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
        <Dependencies>
          <Implicit />
        </Dependencies>
        <MetaInfo connection="Output">
          <RecordInfo>
