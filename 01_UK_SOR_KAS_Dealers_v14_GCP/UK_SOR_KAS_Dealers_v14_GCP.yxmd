            <Field name="DEALER" size="16384" source="File: aka:GCP_BQ|||SELECT&#xA;  DISTINCT INV.EDWAZ28_SEL_DLR_MKT_I2_CNTRY_C AS MARKET,&#xA;  INV.EDWAZ28_MAPPED_SELL_DLR_C AS DEALER,&#xA;  --RD.EDWA006_MAPPED_DEPT_TYPE_F,&#xA;  --INV.EDWAO26_INVOICE_TYPE_C,&#xA;  CASE&#xA;    WHEN RD.EDWA006_MAPPED_DEPT_TYPE_F IS NULL THEN INV.EDWAO26_INVOICE_TYPE_C&#xA;    WHEN INV.EDWAO26_INVOICE_TYPE_C IS NULL THEN RD.EDWA006_MAPPED_DEPT_TYPE_F&#xA;    ELSE RD.EDWA006_MAPPED_DEPT_TYPE_F&#xA;  END&#xA;    AS DEPARTMENT,&#xA;  INV.EDWAZ12_MAPPED_PMT_TYPE_C AS PAYMENT_TYPE,&#xA;  INV.EDWAO26_INVOICE_Y AS INV_DATE,&#xA;  INV.EDWAO26_INVOICE_INDICATOR_C AS INVOICE_TYPE,&#xA;  INV.EDWAO26_NET_TOTAL_INV_VALUE_A AS INV_TOTAL_LOCAL,&#xA;  VEH.EDWAO28_VIN_C AS VIN,&#xA;  VEH.EDWAO28_REGISTRATION_PLATE_C AS REG_PLATE,&#xA;  CASE&#xA;    WHEN RD.EDWA006_VEH_TYPE_C IS NULL THEN '#'&#xA;    ELSE RD.EDWA006_VEH_TYPE_C&#xA;  END&#xA;    AS VEH_TYPE,&#xA;  CASE&#xA;    WHEN RD.EDWA006_VEH_ENG_FUEL_TYPE_C IS NULL THEN CASE&#xA;    WHEN VEH.EDWAO28_FUEL_INDICATOR_C = 'P' THEN 'G'&#xA;    ELSE VEH.EDWAO28_FUEL_INDICATOR_C&#xA;  END&#xA;      ELSE RD.EDWA006_VEH_ENG_FUEL_TYPE_C&#xA;  END&#xA;    AS FUEL_TYPE,&#xA;  TR.SSAVA02_VEH_DESCRIPTION_N AS VEH_DESCRIPTION,&#xA;  CUST.EDWAO30_ACCOUNT_C AS ACCOUNT_CODE,&#xA;  CUST.EDWAO30_CUST_DISPLAY_N AS CUSTOMER_NAME_AGREGATED,&#xA;  CUST.EDWAO30_CUST_DISPLAY_ADDR_X AS CUSTOMER_ADD_AGREGATED,&#xA;  CUST.EDWAO30_ORIG_LST_N AS LAST_NAME,&#xA;  CUST.EDWAO30_ORIG_1ST_N AS FIRST_NAME,&#xA;  CUST.EDWAO30_ORIG_TITLE_N AS TITLE_,&#xA;  CUST.EDWAO30_ORIG_COMP_1ST_N AS COMPANY_NAME_1,&#xA;  CUST.EDWAO30_ORIG_COMP_2ND_N AS COMPANY_NAME_2,&#xA;  CUST.EDWAO30_ORIG_STREET_N AS STREET,&#xA;  CUST.EDWAO30_ORIG_CITY_RGN_N AS REGION,&#xA;  CUST.EDWAO30_ORIG_CITY_N AS CITY,&#xA;  CUST.EDWAO30_ORIG_CNTY_N AS COUNTY,&#xA;  CUST.EDWAO30_ORIG_POSTCODE_C AS POSTCODE,&#xA;  CUST.EDWAO30_ORIG_ADDR_L_1_X AS ADDR_1,&#xA;  CUST.EDWAO30_ORIG_ADDR_L_2_X AS ADDR_2,&#xA;  CUST.EDWAO30_O