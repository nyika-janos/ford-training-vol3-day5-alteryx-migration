            <Node ToolID="17">
              <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
                <Position x="185" y="269" />
              </GuiSettings>
              <Properties>
                <Configuration>
                  <Passwords />
                  <CachedCosmeticName />
                  <File RecordLimit="" FileFormat="23">aka:GCP_BQ|||select substr(customer.MRKT_MARKET_C, 2, 3) as market,
	customer.MKT_CUSTOMER_ID_C as DealerCode,
	sales.SBASEPRT_NBR as FINIS,
	parts.PTHR_PRODUCT_C as MLI,
	sales.MDSMT_MNTHYR_Y as Months,
	Sum(sales.SALES_RETAIL_REV_A / xrates.MONEX_B_RATE_R) as LOC_RRP,
	Sum(sales.SALES_GROSS_REV_A / xrates.MONEX_B_RATE_R) as LOC_BDN,
	Sum(sales.SALES_RETAIL_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as USD_RRP,
	Sum(sales.SALES_GROSS_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as USD_BDN,
	Sum(sales.SALES_BILLED_REV_A / (xrates.MONEX_B_RATE_R)) as billed_revenue,
	Sum(sales.SALES_GROSS_PART_T) as qty 
from `........................GFIN_VIEW.SGFDM06` as sales 
	inner join `........................GFIN_VIEW.SGFDP01` as parts on parts.SBASEPRT_NBR = sales.SBASEPRT_NBR and parts.SPRFXPRT_PREFIX_R = sales.SPRFXPRT_PREFIX_R 
	inner join `........................GFIN_VIEW.SGFDM01` as customer on customer.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and customer.MKT_CUSTOMER_ID_C = sales.MKT_CUSTOMER_ID_C 
	inner join `........................GFIN_VIEW.SGFDC21` as xrates on xrates.MONEX_MNTHYR_Y = sales.MDSMT_MNTHYR_Y 
	inner join `........................GFIN_VIEW.SGFDC12` as curr on curr.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and curr.FUND_CODE_C = xrates.FUND_CODE_C 
	inner join `........................GFIN_VIEW.SGFDC21` as xrates2 on xrates2.FUND_CODE_C = xrates.FUND_CODE_C 
where substr(customer.MRKT_MARKET_C, 2, 3) in ('HUN') 
	and sales.MDSMT_MNTHYR_Y Between 202101 
	and 202612 
	and xrates2.MONEX_MNTHYR_Y = 202601 
	and customer.MNMKT_MAIN_MKT_C Like 'D%' 
	and customer.MKT_CUST_TYPE_C Like '%1' 
group by customer.MKT_CUSTOMER_ID_C, sales.SBASEPRT_NBR, parts.PTHR_PRODUCT_C, sales.MDSMT_MNTHYR_Y, customer.MRKT_MARKET_C</File>
