            <Node ToolID="12">
              <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
                <Position x="389" y="296" />
              </GuiSettings>
              <Properties>
                <Configuration>
                  <Passwords />
                  <File RecordLimit="" FileFormat="23">odbc:DSN=GCP_BQ|||select substr(customer.MRKT_MARKET_C, 2, 3) as market,
	customer.MKT_CUSTOMER_ID_C,
	customer.SSA_TRADE_N,
	sales.COUNTRY_ISO3_C as billing_country,
	sales.SBASEPRT_NBR as FINIS,
	parts.PTHR_PRODUCT_C as MLI,
	sales.MDSMT_MNTHYR_Y,
	Sum(sales.SALES_GROSS_REV_A / xrates.MONEX_B_RATE_R) as LOC_BDN,
	Sum(sales.SALES_GROSS_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as gross_revenue,
	Sum(sales.SALES_BILLED_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as billed_revenue,
	Sum(sales.SALES_GROSS_PART_T) as gross_pieces 
from `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDM06` as sales 
	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDP01` as parts on parts.SBASEPRT_NBR = sales.SBASEPRT_NBR and parts.SPRFXPRT_PREFIX_R = sales.SPRFXPRT_PREFIX_R 
	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDM01` as customer on customer.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and customer.MKT_CUSTOMER_ID_C = sales.MKT_CUSTOMER_ID_C 
	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC21` as xrates on xrates.MONEX_MNTHYR_Y = sales.MDSMT_MNTHYR_Y 
	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC12` as curr on curr.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and curr.FUND_CODE_C = xrates.FUND_CODE_C 
	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC21` as xrates2 on xrates2.FUND_CODE_C = xrates.FUND_CODE_C 
where substr(customer.MRKT_MARKET_C, 2, 3) in ('NLD') 
	and sales.MDSMT_MNTHYR_Y Between 202601 
	and 202612 
	and xrates2.MONEX_MNTHYR_Y = 202601 
	and customer.MNMKT_MAIN_MKT_C Like 'D' 
	and customer.MKT_CUST_TYPE_C Like '1' 
group by customer.MKT_CUSTOMER_ID_C, customer.SSA_TRADE_N, sales.COUNTRY_ISO3_C, sales.SBASEPRT_NBR, parts.PTHR_PRODUCT_C, sales.MDSMT_MNTHYR_Y, customer.MRKT_MARKET_C</File>
                  <FormatSpecificOptions>
                    <PreSQL />
                    <PreSQLOnConfig>True</PreSQLOnConfig>
                    <NoProgress>True</NoProgress>
                    <SessionReadOnly>True</SessionReadOnly>
                    <CacheData>False</CacheData>
                    <TableStyle>Quoted</TableStyle>
                    <ReadUncommitted>False</ReadUncommitted>
                    <PostSQL />
                  </FormatSpecificOptions>
                </Configuration>
                <Annotation DisplayMode="0">
                  <Name />
                  <DefaultAnnotationText>DSN=GCP_BQ
Query=select substr(customer.MRKT_...</DefaultAnnotationText>
                  <Left value="False" />
                </Annotation>
                <MetaInfo connection="Output">
                  <RecordInfo>
                    <Field name="market" size="16384" source="File: odbc:DSN=GCP_BQ|||select substr(customer.MRKT_MARKET_C, 2, 3) as market,&#xA;	customer.MKT_CUSTOMER_ID_C,&#xA;	customer.SSA_TRADE_N,&#xA;	sales.COUNTRY_ISO3_C as billing_country,&#xA;	sales.SBASEPRT_NBR as FINIS,&#xA;	parts.PTHR_PRODUCT_C as MLI,&#xA;	sales.MDSMT_MNTHYR_Y,&#xA;	Sum(sales.SALES_GROSS_REV_A / xrates.MONEX_B_RATE_R) as LOC_BDN,&#xA;	Sum(sales.SALES_GROSS_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as gross_revenue,&#xA;	Sum(sales.SALES_BILLED_REV_A / (xrates.MONEX_B_RATE_R / xrates2.MONEX_G_RATE_R)) as billed_revenue,&#xA;	Sum(sales.SALES_GROSS_PART_T) as gross_pieces &#xA;from `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDM06` as sales &#xA;	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDP01` as parts on parts.SBASEPRT_NBR = sales.SBASEPRT_NBR and parts.SPRFXPRT_PREFIX_R = sales.SPRFXPRT_PREFIX_R &#xA;	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDM01` as customer on customer.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and customer.MKT_CUSTOMER_ID_C = sales.MKT_CUSTOMER_ID_C &#xA;	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC21` as xrates on xrates.MONEX_MNTHYR_Y = sales.MDSMT_MNTHYR_Y &#xA;	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC12` as curr on curr.COUNTRY_ISO3_C = sales.COUNTRY_ISO3_C and curr.FUND_CODE_C = xrates.FUND_CODE_C &#xA;	inner join `ford-26a2ac333716a2247a514420.GFIN_VIEW.SGFDC21` as xrates2 on xrates2.FUND_CODE_C = xrates.FUND_CODE_C &#xA;where substr(customer.MRKT_MARKET_C, 2, 3) in ('NLD') &#xA;	and sales.MDSMT_MNTHYR_Y Between 202601 &#xA;	and 202612 &#xA;	and xrates2.MONEX_MNTHYR_Y = 202601 &#xA;	and customer.MNMKT_MAIN_MKT_C Like 'D' &#xA;	and customer.MKT_CUST_TYPE_C Like '1' &#xA;group by customer.MKT_CUSTOMER_ID_C, customer.SSA_TRADE_N, sales.COUNTRY_ISO3_C, sales.SBASEPRT_NBR, parts.PTHR_PRODUCT_C, sales.MDSMT_MNTHYR_Y, customer.MRKT_MARKET_C" type="V_WString" />
